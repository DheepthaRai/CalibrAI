# ─── Dino Bot — Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your values. Never commit .env to git.

# Get this from @BotFather on Telegram (/newbot)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Get this from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Your public HTTPS URL where Telegram will POST updates
# e.g. https://dino-bot.yourdomain.com  (no trailing slash)
# Leave empty to skip webhook auto-registration (useful for local testing with ngrok)
WEBHOOK_URL=

# Port for the HTTP server (default: 3000)
PORT=3000
